# .env.example - FragValue
#
# Liste de toutes les variables d'env utilisees en prod.
# Copie ce fichier en .env.local pour le dev, puis ajoute les vraies valeurs.
# Ne JAMAIS commiter .env.local (il est dans .gitignore).
#
# Pour la prod : configure-les dans Vercel > Settings > Environment Variables
# (Production + Preview + Development selon le scope).

# ─── Supabase ────────────────────────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGc...                   # Service role JWT (cote serveur uniquement, JAMAIS en client)

# ─── Stripe (live mode) ──────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...                     # ou sk_test_... en dev
STRIPE_WEBHOOK_SECRET=whsec_...                   # legacy, garder pour fallback
STRIPE_WEBHOOKLIVE_SECRET=whsec_...                # priorite absolue (mode live)
STRIPE_PRICE_PRO_MONTHLY=price_xxx
STRIPE_PRICE_PRO_ANNUEL=price_xxx
STRIPE_PRICE_ELITE_MONTHLY=price_xxx
STRIPE_PRICE_ELITE_ANNUEL=price_xxx
STRIPE_PRICE_TEAM_MONTHLY=price_xxx
STRIPE_PRICE_TEAM_ANNUEL=price_xxx
STRIPE_PRICE_COACH_PACK_50=price_xxx              # convention : STRIPE_PRICE_COACH_PACK_<SIZE>
STRIPE_PRICE_COACH_PACK_200=price_xxx

# ─── FACEIT ──────────────────────────────────────────────────────────────
FACEIT_API_KEY=                                   # Server API Key (Data API + Downloads API scope)
FACEIT_CLIENT_ID=                                 # OAuth login user
FACEIT_CLIENT_SECRET=                             # OAuth login user
FACEIT_WEBHOOK_SECRET=                            # Static header value (openssl rand -hex 32)
FACEIT_WEBHOOK_AUTH_HEADER=X-FACEIT-Token         # Optionnel, default X-FACEIT-Token

# ─── Anthropic (Coach IA) ────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Resend (emails transactionnels) ─────────────────────────────────────
RESEND_API_KEY=re_...
RESEND_WEBHOOK_SECRET=                            # signature des webhooks Resend
EMAIL_FROM=FragValue <notifications@send.fragvalue.com>
EMAIL_REPLY_TO=quentin@fragvalue.com
EMAIL_UNSUB_SECRET=                               # HMAC secret pour les liens unsubscribe (openssl rand -hex 32)
FEEDBACK_FORWARD_EMAIL=quentin@fragvalue.com      # destinataire des alertes feedback

# ─── Discord (alertes ops + role assignment) ─────────────────────────────
DISCORD_WEBHOOK_ALERTS=                           # webhook channel #ops-alerts
DISCORD_BOT_TOKEN=                                # bot token pour assigner roles
DISCORD_CLIENT_ID=                                # OAuth Discord
DISCORD_CLIENT_SECRET=                            # OAuth Discord
DISCORD_PUBLIC_KEY=                               # signature verify slash commands
DISCORD_GUILD_ID=                                 # FragValue server ID
DISCORD_ROLE_ID_FREE=
DISCORD_ROLE_ID_PRO=
DISCORD_ROLE_ID_ELITE=
DISCORD_ROLE_ID_EARLY=                            # vider pour fermer la fenetre Early
DISCORD_STATE_SECRET=                             # HMAC OAuth state

# ─── PandaScore (matchs pros, INACTIF jusqu'a Business tier) ──────────────
PANDASCORE_API_TOKEN=

# ─── Parser Railway (CS2 demo parser) ────────────────────────────────────
PARSER_URL=https://fragvalue-demo-parser-production.up.railway.app
PARSER_SECRET=                                    # bearer token partage avec Railway

# ─── Vercel cron ─────────────────────────────────────────────────────────
CRON_SECRET=                                      # auto-genere par Vercel, sert aussi pour appels manuels

# ─── Divers ──────────────────────────────────────────────────────────────
SITE_URL=https://fragvalue.com
PUBLIC_URL=https://fragvalue.com
ADMIN_EMAILS=quentin@fragvalue.com,...            # comma-separated, surclasse FRAGVALUE_ADMIN_EMAILS
FRAGVALUE_ADMIN_EMAILS=                           # legacy, fallback de ADMIN_EMAILS
IP_HASH_SALT=                                     # salt SHA-256 pour anonymiser les IP (feedback)
GA=G-H6PLDKSCJR                                   # GA4 measurement ID

# ─── Auto par Vercel (lecture seule) ─────────────────────────────────────
# VERCEL_ENV=production | preview | development
# VERCEL_URL=mon-deployment.vercel.app
# NODE_ENV=production | development
